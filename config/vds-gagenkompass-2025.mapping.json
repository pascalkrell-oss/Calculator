    },
    "bis_3_module": {
      "label": "Bis 3 Module",
      "input": "range"
    },
    "je_weiteres_modul": {
      "label": "Je weiteres Modul",
      "input": "increment"
    }
  },
  "cross_reference_rules": [
    {
      "id": "online_video_unpaid_to_imagefilm",
      "when": {
        "family": "werbung_mit_bild",
        "case": "online_video_spot",
        "conditions": {
          "media_payment": "unpaid"
        }
      },
      "then": {
        "action": "redirect_case_family",
        "target_family": "webvideo_imagefilm_praesentation_unpaid",
        "target_case": "webvideo_unpaid"
      }
    },
    {
      "id": "online_audio_unpaid_to_imagefilm",
      "when": {
        "family": "werbung_ohne_bild",
        "case": "online_audio_spot",
        "conditions": {
          "media_payment": "unpaid"
        }
      },
      "then": {
        "action": "redirect_case_family",
        "target_family": "webvideo_imagefilm_praesentation_unpaid",
        "target_case": "webvideo_unpaid"
      }
    },
    {
      "id": "telefon_werbespot_to_audio_advertising",
      "when": {
        "family": "telefonansage",
        "case": "telefon_werbespot"
      },
      "then": {
        "action": "redirect_case_family",
        "target_family": "werbung_ohne_bild",
        "target_case": "telefon_werbespot"
      }
    },
    {
      "id": "reine_telefonansage_stays_phone",
      "when": {
        "family": "telefonansage",
        "case": "telefonansage",
        "conditions": {
          "promotional_intent": false
        }
      },
      "then": {
        "action": "stay_in_case"
      }
    },
    {
      "id": "inapp_ads_to_advertising_with_visual",
      "when": {
        "family": "app",
        "case": "inapp_ad"
      },
      "then": {
        "action": "redirect_case_family",
        "target_family": "werbung_mit_bild",
        "target_case": "online_video_spot"
      }
    },
    {
      "id": "internal_elearning_stays_elearning",
      "when": {
        "family": "elearning_audioguide",
        "case": "elearning_intern"
      },
      "then": {
        "action": "stay_in_case"
      }
    },
    {
      "id": "marketing_elearning_to_webvideo",
      "when": {
        "family": "elearning_audioguide",
        "case": "elearning_marketing",
        "conditions": {
          "audience": "public"
        }
      },
      "then": {
        "action": "redirect_case_family",
        "target_family": "webvideo_imagefilm_praesentation_unpaid",
        "target_case": "imagefilm_marketing"
      }
    },
    {
      "id": "podcast_promotional_to_audio_advertising",
      "when": {
        "family": "podcast",
        "case": "podcast_werblich"
      },
      "then": {
        "action": "redirect_case_family",
        "target_family": "werbung_ohne_bild",
        "target_case": "funk_spot"
      }
    },
    {
      "id": "games_promotional_to_advertising_with_visual",
      "when": {
        "family": "games",
        "case": "game_werbliche_nutzung"
      },
      "then": {
        "action": "redirect_case_family",
        "target_family": "werbung_mit_bild",
        "target_case": "online_video_spot"
      }
    }
  ],
