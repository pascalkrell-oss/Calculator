      "label": "Netto-Sendeminute",
      "input": "decimal"
    },
    "studiostunde": {
      "label": "Studiostunde",
      "input": "decimal"
    },
    "fah": {
      "label": "Final Audio Hour",
      "input": "decimal"
    },
